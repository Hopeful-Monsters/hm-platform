# Supabase — from Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://[project-ref].supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Upstash Redis — rate limiting (api, ai, and auth limiters)
UPSTASH_REDIS_REST_URL=https://[instance].upstash.io
UPSTASH_REDIS_REST_TOKEN=AX...

# Resend — transactional email (signup notifications, approval confirmations)
RESEND_API_KEY=re_...

# Admin notification email — receives new signup alerts and approval confirmations
ADMIN_EMAIL=admin@hopefulmonsters.com.au

# Linear — Support form issue creation
# API key: Linear → Settings → API → Personal API keys (or workspace key)
# Team ID: Settings → Teams → click team → copy UUID from the URL
LINEAR_API_KEY=lin_api_...
LINEAR_TEAM_ID=

# Gemini — receipt extraction in Expenses Manager
GEMINI_KEY=AI...

# Streamtime — Expenses Manager
# API key: Streamtime → Settings → Integrations → API
STREAMTIME_KEY=

# Google Drive — Expenses Manager (server-side OAuth, full drive scope)
# Client ID + Secret: Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client ID
# Authorised redirect URI must include: https://[your-domain]/api/expenses-manager/drive/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Optional: restrict uploads to a specific Drive folder (top-level folder ID from the Drive URL)
EXPENSES_DRIVE_FOLDER_ID=